{
  "name": "domera",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "analyze:excel": "tsx scripts/analyzeExcelStructure.ts",
    "import:apartments": "tsx scripts/importApartmentsFromExcel.ts",
    "migrate:waterReadings": "tsx scripts/migrateWaterReadings.ts",
    "migrate:invitationTokens": "tsx scripts/migrateInvitationTokens.ts",
    "cleanup:invitations": "tsx scripts/cleanupExpiredInvitations.ts",
    "test:rules:run": "tsx tests/security/firestore.rules.test.ts",
    "test:rules": "firebase emulators:exec --only firestore \"npm run test:rules:run\"",
    "security:regression": "tsx scripts/securityRegression.ts",
    "security:secrets": "tsx scripts/checkCommittedSecrets.ts",
    "security:release-gate": "npm run lint && npm run typecheck && npm run build && npm run security:secrets && npm run test:rules && npm run security:regression"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "jszip": "^3.10.1",
    "lucide": "^0.575.0",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-intl": "^4.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "react-icons-kit": "^2.0.0",
    "react-toastify": "^11.0.5",
    "resend": "^6.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "firebase-tools": "^14.23.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
