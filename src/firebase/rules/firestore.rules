rules_version = '2';

// ALIGNMENT NOTE: These Firestore rules are the second line of defence.
// Every collection rule here has a corresponding server-side ownership check
// in src/app/api/**. When schema changes, update both in the same PR so they
// stay in sync. Tests live in tests/security/firestore.rules.test.ts.

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userDocExists() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return request.auth.token.role != null
        ? request.auth.token.role
        : (userDocExists() ? userDoc().role : null);
    }

    function userCompanyId() {
      return request.auth.token.companyId != null
        ? request.auth.token.companyId
        : (userDocExists() ? userDoc().companyId : null);
    }

    function userApartmentId() {
      return request.auth.token.apartmentId != null
        ? request.auth.token.apartmentId
        : (userDocExists() ? userDoc().apartmentId : null);
    }

    function isManagementStaff() {
      return isAuthenticated() && userRole() in ['ManagementCompany', 'Accountant'];
    }

    function isResident() {
      return isAuthenticated() && userRole() == 'Resident';
    }

    function hasCompanyAccess(companyId) {
      return companyId != null && userCompanyId() != null && userCompanyId() == companyId;
    }

    function hasApartmentAccess(apartmentId) {
      return apartmentId != null && userApartmentId() != null && userApartmentId() == apartmentId;
    }

    function apartmentHasCompanyAccess(companyIds) {
      return companyIds is list
        && userCompanyId() != null
        && companyIds.hasAny([userCompanyId()]);
    }

    match /companies/{companyId} {
      allow read: if isManagementStaff() && hasCompanyAccess(companyId);
      allow create: if isManagementStaff() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isManagementStaff() && hasCompanyAccess(companyId);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId
        || (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
      );

      allow create: if isAuthenticated() && request.auth.uid == userId;

      allow update: if isAuthenticated() && (
        request.auth.uid == userId
        || (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
      );

      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /buildings/{buildingId} {
      allow read: if isAuthenticated() && (
        (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
        || (isResident() && resource.data.apartmentIds is list && resource.data.apartmentIds.hasAny([userApartmentId()]))
      );

      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /apartments/{apartmentId} {
      allow read: if isAuthenticated() && (
        (isManagementStaff() && apartmentHasCompanyAccess(resource.data.companyIds))
        || (isResident() && hasApartmentAccess(apartmentId))
      );

      allow create: if isManagementStaff() && apartmentHasCompanyAccess(request.resource.data.companyIds);
      allow update: if isManagementStaff() && apartmentHasCompanyAccess(resource.data.companyIds);
      allow delete: if isManagementStaff() && apartmentHasCompanyAccess(resource.data.companyIds);
    }

    match /meters/{meterId} {
      allow read: if isAuthenticated() && (
        (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
        || (isResident() && hasApartmentAccess(resource.data.apartmentId))
      );

      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /meter_readings/{readingId} {
      allow read: if isAuthenticated() && (
        (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
        || (isResident() && hasApartmentAccess(resource.data.apartmentId))
      );

      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
        || (isResident() && hasApartmentAccess(resource.data.apartmentId))
      );

      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /invitations/{invitationId} {
      allow read: if isManagementStaff() && hasCompanyAccess(resource.data.companyId)
        || (isResident() && hasApartmentAccess(resource.data.apartmentId));
      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /company_invitations/{invitationId} {
      allow read: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if false;
    }

    match /news/{newsId} {
      allow read: if isAuthenticated() && (
        (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
        || (isResident() && hasCompanyAccess(resource.data.companyId))
      );

      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        (isManagementStaff() && hasCompanyAccess(resource.data.companyId))
        || (isResident() && hasCompanyAccess(resource.data.companyId))
      );

      allow create: if isManagementStaff() && hasCompanyAccess(request.resource.data.companyId);
      allow update: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
      allow delete: if isManagementStaff() && hasCompanyAccess(resource.data.companyId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
